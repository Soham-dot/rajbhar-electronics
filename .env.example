# Optional: webhook endpoint to receive Contact + Booking leads as JSON payloads.
# Example targets: Pipedream, Zapier Catch Hook, Make.com webhook, Google Apps Script webhook.
LEADS_WEBHOOK_URL=

# Optional: direct email notifications via Resend.
# Set RESEND_API_KEY from your Resend dashboard.
RESEND_API_KEY=

# Required for email channel when RESEND_API_KEY is set.
# Use a verified sender in Resend (or onboarding@resend.dev during initial testing).
LEADS_FROM_EMAIL=

# Optional: where lead notifications are sent. Defaults to BUSINESS.email when empty.
LEADS_NOTIFY_EMAIL=

# Optional: store leads in PostgreSQL (recommended for long-term records).
# Any Neon/Postgres connection string works; DATABASE_URL is fallback if POSTGRES_URL is empty.
POSTGRES_URL=
DATABASE_URL=

# Required for admin dashboard authentication.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Optional but strongly recommended for secure session cookies.
ADMIN_SESSION_SECRET=

# Optional: session expiry in hours (default: 24).
ADMIN_SESSION_TTL_HOURS=9
