{
  "name": "rajbhar-electronics",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check:tracked-imports": "node scripts/check-tracked-imports.mjs",
    "verify": "npm run check:tracked-imports && npm run typecheck && npm run lint && npm run build",
    "setup:hooks": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-hooks.ps1",
    "sync": "git add . && git commit -m"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "autoprefixer": "^10.4.27",
    "lucide-react": "^0.577.0",
    "next": "^15.5.12",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "^15.5.12",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
